generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  toolUsages    ToolUsage[]
  contacts      Contact[]
  products      Product[]
  expenses      Expense[]
  projects      Project[]
  tickets       Ticket[]
  appointments  Appointment[]
  quotations    Quotation[]
  vendors       Vendor[]
  employees     Employee[]
  assets        Asset[]
  complaints    Complaint[]
  deals         Deal[]
  contracts     Contract[]
  repairTickets RepairTicket[]
  transactions  Transaction[]
  articles      Article[]
  invoices      Invoice[]
  timeEntries   TimeEntry[]
  campaigns     Campaign[]
  documents     Document[]
  surveys       Survey[]
  bookings      Booking[]
  analyticsData AnalyticsData[]
  teamMembers   TeamMember[]
  reports       Report[]
  settings      UserSettings?
  subscriptions SubscriptionPlan[]
  workflows     Workflow[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                   PlanTier           @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  lsCustomerId           String?
  lsSubscriptionId       String?            @unique
  lsVariantId            String?
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

// Tracks free-tier daily usage per tool to enforce paywall limits.
model ToolUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      String
  date      DateTime @default(now()) @db.Date
  count     Int      @default(1)

  @@unique([userId, tool, date])
}

enum ContactStatus {
  LEAD
  CUSTOMER
  INACTIVE
}

model Contact {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  company   String?
  status    ContactStatus @default(LEAD)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model Product {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  sku       String?
  price     Float    @default(0)
  stock     Int      @default(0)
  lowStockAt Int     @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Expense {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String
  category  String
  amount    Float
  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())

  @@index([userId])
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
}

model Project {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  status    ProjectStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  tasks     Task[]

  @@index([userId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  status    TaskStatus @default(TODO)
  dueDate   DateTime?
  createdAt DateTime   @default(now())

  @@index([projectId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model Ticket {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  description String?
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  requesterName  String?
  requesterEmail String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  clientName String
  startTime DateTime
  durationMinutes Int         @default(30)
  status    AppointmentStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime          @default(now())

  @@index([userId])
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model Quotation {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  quoteNumber String
  clientName  String
  items       Json
  status      QuotationStatus @default(DRAFT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
}

model Vendor {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  category  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

model Employee {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  designation String?
  department  String?
  monthlySalary Float           @default(0)
  joinDate    DateTime          @default(now()) @db.Date
  status      EmployeeStatus    @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  attendance  AttendanceRecord[]
  payslips    Payslip[]
  assets      Asset[]

  @@index([userId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  createdAt  DateTime         @default(now())

  @@unique([employeeId, date])
  @@index([employeeId])
}

model Payslip {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month        String
  basicSalary  Float
  deductions   Float    @default(0)
  netPay       Float
  createdAt    DateTime @default(now())

  @@unique([employeeId, month])
  @@index([employeeId])
}

enum AssetStatus {
  IN_USE
  IN_STORAGE
  RETIRED
}

model Asset {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  category     String?
  serialNumber String?
  value        Float       @default(0)
  status       AssetStatus @default(IN_STORAGE)
  assignedToId String?
  assignedTo   Employee?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  purchaseDate DateTime?   @db.Date
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
}

enum ComplaintStatus {
  OPEN
  INVESTIGATING
  RESOLVED
}

model Complaint {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  complainantName String
  subject         String
  description     String?
  status          ComplaintStatus @default(OPEN)
  resolutionNotes String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
}

enum DealStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model Deal {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  clientName        String
  value             Float     @default(0)
  stage             DealStage @default(NEW)
  expectedCloseDate DateTime? @db.Date
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  counterparty String
  startDate    DateTime       @db.Date
  endDate      DateTime?      @db.Date
  value        Float          @default(0)
  status       ContractStatus @default(DRAFT)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
}

enum RepairStatus {
  RECEIVED
  IN_PROGRESS
  COMPLETED
  DELIVERED
}

model RepairTicket {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemName    String
  customerName String
  issue       String
  cost        Float        @default(0)
  status      RepairStatus @default(RECEIVED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Transaction {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerName  String?
  items         Json
  subtotal      Float               @default(0)
  tax           Float               @default(0)
  total         Float               @default(0)
  paymentMethod String?
  status        TransactionStatus   @default(COMPLETED)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
}

model Article {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  slug      String
  content   String   @db.Text
  category  String?
  status    String   @default("PUBLISHED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceNumber String
  clientName    String
  clientEmail   String?
  items         Json
  subtotal      Float         @default(0)
  tax           Float         @default(0)
  total         Float         @default(0)
  dueDate       DateTime?     @db.Date
  status        InvoiceStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
}

enum TimeEntryStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model TimeEntry {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectName String
  taskName    String
  hours       Float            @default(0)
  date        DateTime         @db.Date
  description String?
  status      TimeEntryStatus  @default(COMPLETED)
  billable    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  recipients  Json
  status      String   @default("DRAFT")
  sentAt      DateTime?
  openCount   Int      @default(0)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Document {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  fileName    String
  fileSize    Int
  fileType    String
  category    String?
  tags        Json
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Survey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  questions   Json
  responses   Json
  status      String   @default("OPEN")
  responseCount Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientName    String
  clientEmail   String?
  clientPhone   String?
  serviceType   String
  date          DateTime
  duration      Int
  location      String?
  notes         String?
  status        String   @default("CONFIRMED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model AnalyticsData {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric      String
  value       Float
  date        DateTime @default(now()) @db.Date
  source      String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model TeamMember {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  email       String
  role        String
  department  String?
  joinDate    DateTime @default(now()) @db.Date
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  type        String
  data        Json
  generatedAt DateTime @default(now())
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())

  @@index([userId])
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme              String   @default("LIGHT")
  timezone           String   @default("UTC")
  language           String   @default("EN")
  notificationsEmail Boolean  @default(true)
  notificationsSms   Boolean  @default(false)
  twoFactorEnabled   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  interval    String
  features    Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Workflow {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  trigger      String
  actions      Json
  isActive     Boolean  @default(true)
  executionLog Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}
